    {
      "name": "07. Analytics",
      "item": [
        {
          "name": "Get System Stats (Principal Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    console.log('✅ Analytics retrieved');",
                  "    console.log('By Subject:', response.data.bySubject);",
                  "    console.log('Top Content:', response.data.topContent);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
