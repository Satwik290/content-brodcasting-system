{
  "info": {
    "name": "Content Broadcasting System API - Complete v2.0",
    "_postman_id": "cbs-api-complete-v2",
    "description": "Complete API collection for Content Broadcasting System with:\n- Auth flows (Register, Login, Logout)\n- Teacher workflows (Upload, View Uploads)\n- Principal workflows (Review, Approve, Reject)\n- Public Broadcasting (Live Feed)\n- User Management\n- Analytics\n\n**Setup Instructions:**\n1. Set baseUrl: http://localhost:3000/api/v1\n2. Run 'Register Teacher' first\n3. Run 'Register Principal' second\n4. Run 'Login as Teacher' (auto-sets teacherToken)\n5. Run 'Login as Principal' (auto-sets principalToken)\n6. Use 'Upload Content' to create content\n7. Use 'View Pending Reviews' to see it\n8. Approve/Reject as needed",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "teacherToken", "value": "", "type": "string" },
    { "key": "principalToken", "value": "", "type": "string" },
    { "key": "teacherId", "value": "", "type": "string" },
    { "key": "contentId", "value": "", "type": "string" },
    { "key": "timestamp", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "00. SETUP (Run these first)",
      "item": [
        {
          "name": "0.1 - Register Teacher Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Register Teacher Response:', response);",
                  "",
                  "if (response.success && response.data?.token) {",
                  "    pm.collectionVariables.set('teacherToken', response.data.token);",
                  "    pm.collectionVariables.set('teacherId', response.data.user.id);",
                  "    console.log('✅ Teacher token saved:', response.data.user.email);",
                  "} else {",
                  "    console.log('❌ Failed to register teacher');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Teacher\",\n  \"email\": \"teacher.{{$timestamp}}@school.com\",\n  \"password\": \"TeacherPass123!\",\n  \"role\": \"TEACHER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "0.2 - Register Principal Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Register Principal Response:', response);",
                  "",
                  "if (response.success && response.data?.token) {",
                  "    pm.collectionVariables.set('principalToken', response.data.token);",
                  "    console.log('✅ Principal token saved:', response.data.user.email);",
                  "} else {",
                  "    console.log('❌ Failed to register principal');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Principal Smith\",\n  \"email\": \"principal.{{$timestamp}}@school.com\",\n  \"password\": \"PrincipalPass123!\",\n  \"role\": \"PRINCIPAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "01. Authentication",
      "item": [
        {
          "name": "Login as Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Teacher Login Response:', response);",
                  "",
                  "if (response.success && response.data?.token) {",
                  "    pm.collectionVariables.set('teacherToken', response.data.token);",
                  "    pm.collectionVariables.set('teacherId', response.data.user.id);",
                  "    console.log('✅ Logged in as:', response.data.user.email);",
                  "    console.log('✅ Token saved - ready to upload content');",
                  "} else {",
                  "    console.log('❌ Login failed');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher.1234567890123@school.com\",\n  \"password\": \"TeacherPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login as Principal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Principal Login Response:', response);",
                  "",
                  "if (response.success && response.data?.token) {",
                  "    pm.collectionVariables.set('principalToken', response.data.token);",
                  "    console.log('✅ Logged in as:', response.data.user.email);",
                  "    console.log('✅ Token saved - ready to review content');",
                  "} else {",
                  "    console.log('❌ Login failed');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal.1234567890123@school.com\",\n  \"password\": \"PrincipalPass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    pm.collectionVariables.set('teacherToken', '');",
                  "    pm.collectionVariables.set('principalToken', '');",
                  "    console.log('✅ Logged out - tokens cleared');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "02. Teacher - Upload Content",
      "item": [
        {
          "name": "Upload Image - Math Quiz",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = new Date();",
                  "const startTime = now.toISOString();",
                  "const endTime = new Date(now.getTime() + 8 * 3600 * 1000).toISOString(); // 8 hours from now",
                  "pm.collectionVariables.set('startTime', startTime);",
                  "pm.collectionVariables.set('endTime', endTime);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Upload Response:', response);",
                  "",
                  "if (response.success && response.data?.id) {",
                  "    pm.collectionVariables.set('contentId', response.data.id);",
                  "    console.log('✅ Content uploaded successfully');",
                  "    console.log('   Content ID:', response.data.id);",
                  "    console.log('   Status:', response.data.status);",
                  "    console.log('   Subject:', response.data.subject);",
                  "    console.log('   👉 Next: View Pending Reviews (as Principal)');",
                  "} else {",
                  "    console.log('❌ Upload failed:', response.error?.message);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Mathematics Quiz - Basic Arithmetic",
                  "type": "text"
                },
                {
                  "key": "subject",
                  "value": "maths",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Weekly quiz covering addition, subtraction, and multiplication for Grade 3",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "startTime",
                  "value": "{{startTime}}",
                  "type": "text"
                },
                {
                  "key": "endTime",
                  "value": "{{endTime}}",
                  "type": "text"
                },
                {
                  "key": "rotationDuration",
                  "value": "5",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["content", "upload"]
            }
          }
        },
        {
          "name": "Upload Image - Science Experiment",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = new Date();",
                  "const startTime = now.toISOString();",
                  "const endTime = new Date(now.getTime() + 8 * 3600 * 1000).toISOString();",
                  "pm.collectionVariables.set('startTime', startTime);",
                  "pm.collectionVariables.set('endTime', endTime);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    console.log('✅ Science content uploaded:', response.data.title);",
                  "    console.log('   Content ID:', response.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Science Experiment - Water Cycle",
                  "type": "text"
                },
                {
                  "key": "subject",
                  "value": "science",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Visual explanation of evaporation, condensation, and precipitation",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "startTime",
                  "value": "{{startTime}}",
                  "type": "text"
                },
                {
                  "key": "endTime",
                  "value": "{{endTime}}",
                  "type": "text"
                },
                {
                  "key": "rotationDuration",
                  "value": "5",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["content", "upload"]
            }
          }
        }
      ]
    },
    {
      "name": "03. Teacher - View Uploads",
      "item": [
        {
          "name": "View My Uploads (All)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Your Uploads:', response.data);",
                  "",
                  "if (response.data?.items?.length > 0) {",
                  "    console.log('✅ Found', response.data.items.length, 'uploads');",
                  "    response.data.items.forEach((item, i) => {",
                  "        console.log(`  ${i+1}. ${item.title} (${item.status})`);",
                  "    });",
                  "} else {",
                  "    console.log('No uploads yet');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/content/my-uploads?limit=10&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["content", "my-uploads"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "View My Uploads (Math Only)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/content/my-uploads?subject=maths&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["content", "my-uploads"],
              "query": [
                { "key": "subject", "value": "maths" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "04. Principal - Review & Approve",
      "item": [
        {
          "name": "View Pending Reviews",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Pending Reviews:', response.data);",
                  "",
                  "if (response.data?.items?.length > 0) {",
                  "    console.log('✅ Found', response.data.items.length, 'pending content');",
                  "    response.data.items.forEach((item, i) => {",
                  "        console.log(`  ${i+1}. ${item.title} (by ${item.author?.name})`);",
                  "        pm.collectionVariables.set('contentId', item.id);",
                  "        console.log('     👉 ID saved:', item.id);",
                  "    });",
                  "} else {",
                  "    console.log('No pending reviews');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{principalToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/content/admin/pending?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["content", "admin", "pending"],
              "query": [
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Approve Content",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Approve Response:', response);",
                  "",
                  "if (response.success) {",
                  "    console.log('✅ Content approved successfully!');",
                  "    console.log('   Title:', response.data.title);",
                  "    console.log('   Status:', response.data.status);",
                  "    console.log('   Approved At:', response.data.approvedAt);",
                  "    console.log('👉 Next: Test Live Feed endpoint');",
                  "} else {",
                  "    console.log('❌ Approval failed:', response.error?.message);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{principalToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{baseUrl}}/content/admin/{{contentId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["content", "admin", "{{contentId}}", "approve"]
            }
          }
        },
        {
          "name": "Reject Content",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success) {",
                  "    console.log('✅ Content rejected');",
                  "    console.log('   Status:', response.data.status);",
                  "    console.log('   Reason:', response.data.rejectionReason);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{principalToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Image quality is too low. Please resubmit with higher resolution.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/content/admin/{{contentId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["content", "admin", "{{contentId}}", "reject"]
            }
          }
        },
        {
          "name": "View All Content (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{principalToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/content/admin/all?status=APPROVED&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["content", "admin", "all"],
              "query": [
                { "key": "status", "value": "APPROVED" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "05. Public - Broadcasting",
      "item": [
        {
          "name": "Get Live Content (All Subjects)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Live Content:', response.data);",
                  "",
                  "if (response.data?.content) {",
                  "    console.log('✅ Content is live!');",
                  "    console.log('   Title:', response.data.content.title);",
                  "    console.log('   Subject:', response.data.content.subject);",
                  "    console.log('   Active Until:', response.data.content.activeUntil);",
                  "    console.log('   Cached:', response.cached);",
                  "    if (response.data.content.rotationInfo) {",
                  "        console.log('   Rotation Info:');",
                  "        console.log('     - Total Content in Rotation:', response.data.content.rotationInfo.totalContents);",
                  "        console.log('     - Current Index:', response.data.content.rotationInfo.currentIndex);",
                  "        console.log('     - Time Remaining:', response.data.content.rotationInfo.remainingSeconds, 'seconds');",
                  "    }",
                  "} else {",
                  "    console.log('ℹ️ No content available:', response.data?.message);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/content/live/{{teacherId}}",
              "host": ["{{baseUrl}}"],
              "path": ["content", "live", "{{teacherId}}"]
            }
          }
        },
        {
          "name": "Get Live Content (Math Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data?.content) {",
                  "    console.log('✅ Math content is live:', response.data.content.title);",
                  "} else {",
                  "    console.log('ℹ️ No math content available');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/content/live/{{teacherId}}?subject=maths",
              "host": ["{{baseUrl}}"],
              "path": ["content", "live", "{{teacherId}}"],
              "query": [
                { "key": "subject", "value": "maths" }
              ]
            }
          }
        },
        {
          "name": "Get Live Content (Invalid Subject - Edge Case)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "console.log('Response:', response);",
                  "",
                  "if (response.success && !response.data?.content) {",
                  "    console.log('✅ Edge case handled correctly');",
                  "    console.log('   Returns 200 OK with null content (not an error)');",
                  "    console.log('   Message:', response.data?.message);",
                  "} else {",
                  "    console.log('❌ Edge case NOT handled correctly');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/content/live/{{teacherId}}?subject=invalid_subject",
              "host": ["{{baseUrl}}"],
              "path": ["content", "live", "{{teacherId}}"],
              "query": [
                { "key": "subject", "value": "invalid_subject" }
              ]
            }
          }
        }
      ]
    },
