    {
      "name": "09. DEMO WORKFLOW (Run in Order)",
      "item": [
        {
          "name": "1. Setup - Register Accounts",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Teacher\",\n  \"email\": \"demo.teacher.{{$timestamp}}@school.com\",\n  \"password\": \"DemoPass123!\",\n  \"role\": \"TEACHER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "2. Teacher - Upload Content",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const now = new Date();",
                  "const startTime = now.toISOString();",
                  "const endTime = new Date(now.getTime() + 8 * 3600 * 1000).toISOString();",
                  "pm.collectionVariables.set('startTime', startTime);",
                  "pm.collectionVariables.set('endTime', endTime);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{teacherToken}}" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Demo Content - Physics Experiment", "type": "text" },
                { "key": "subject", "value": "science", "type": "text" },
                { "key": "description", "value": "Demonstrating Newton's Laws of Motion", "type": "text" },
                { "key": "file", "type": "file", "src": [] },
                { "key": "startTime", "value": "{{startTime}}", "type": "text" },
                { "key": "endTime", "value": "{{endTime}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/content/upload",
              "host": ["{{baseUrl}}"],
              "path": ["content", "upload"]
            }
          }
        },
        {
          "name": "3. Principal - Review Pending",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{principalToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/content/admin/pending",
              "host": ["{{baseUrl}}"],
              "path": ["content", "admin", "pending"]
            }
          }
        },
        {
          "name": "4. Principal - Approve Content",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{principalToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/content/admin/{{contentId}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["content", "admin", "{{contentId}}", "approve"]
            }
          }
        },
        {
          "name": "5. Student - Access Live Content",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/content/live/{{teacherId}}?subject=science",
              "host": ["{{baseUrl}}"],
              "path": ["content", "live", "{{teacherId}}"],
              "query": [
                { "key": "subject", "value": "science" }
              ]
            }
          }
        }
      ]
    }
